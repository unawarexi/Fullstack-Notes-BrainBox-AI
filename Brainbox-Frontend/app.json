{
  "expo": {
    "name": "Notes-Brainbox",
    "slug": "Notes-Brainbox",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo/Logo.png",
    "scheme": "notesbrainbox",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.brainbox.notesbrainbox"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/logo/Logo.png",
        "backgroundImage": "./assets/logo/Logo.png",
        "monochromeImage": "./assets/logo/Logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package" : "com.brainbox.notesbrainbox"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/logo/Logo.png"
    },
    "plugins": [
      "expo-router",
      
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo/Logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "expo-sqlite",
     [
       "expo-build-properties",
       {
        "ios": {
          "useFrameworks": "static"
        }
       }
     ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
